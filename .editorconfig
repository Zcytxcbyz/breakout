# EditorConfig configuration file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C++ files
[*.{cpp,h,hpp,cc,cxx}]
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 120

# CMake files
[CMakeLists.txt]
indent_style = space
indent_size = 4
tab_width = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 4
tab_width = 4

# JSON files
[*.json]
indent_style = space
indent_size = 2
tab_width = 2

# Git files
[{.gitignore,.gitattributes}]
indent_style = space
indent_size = 4
tab_width = 4
